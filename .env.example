# Copia a .env y ajusta valores locales. No commitees .env.
DATABASE_URL=postgresql+psycopg://epintel:epintel@localhost:5432/epintel
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000
API_INTERNAL_URL=http://localhost:8000

# API operación
LOG_JSON=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120

# Ingestión programada (servicio ingestion-worker en Docker)
INGESTION_SCHEDULE_ENABLED=false
INGESTION_INTERVAL_HOURS=24
INGESTION_DEFAULT_YEARS=2018,2019,2020
INGESTION_DEFAULT_LIMIT=15000
INGESTION_BATCH_SIZE=1000
INGESTION_END_YEAR=2018
INGESTION_VALIDATE_TERRITORIAL_CODES=true

# Token de aplicación Socrata (datos.gov.co) — mejora límites de tasa
# Registro: https://www.datos.gov.co/profile/edit/developer_settings
SOCRATA_APP_TOKEN=

# ML serving (territorial risk)
ML_ARTIFACTS_DIR=

# Seguridad opcional (protege /api/v1/* excepto OpenAPI)
API_KEY=
